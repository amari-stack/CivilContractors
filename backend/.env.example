# Server Port (Render automatically sets PORT in production)
PORT=5000

# MongoDB Atlas Connection String
# Example: mongodb+srv://username:password@cluster0.xxx.mongodb.net/la_contractors?retryWrites=true&w=majority
MONGODB_URL=

# Google Gemini API Key
GEMINI_API_KEY=

# Allowed Client Origin for CORS (e.g. https://your-frontend.onrender.com or * during initial setup)
CLIENT_URL=http://localhost:3000
